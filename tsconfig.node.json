{
  "compilerOptions": {
    // TypeScript 编译信息缓存文件路径
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    // 编译目标为 ES2022
    "target": "ES2022",
    // 使用的 JavaScript 标准库
    "lib": ["ES2023"],
    // 模块系统使用 ESNext（最新 ES 模块语法）
    "module": "ESNext",
    // 跳过类型声明文件的检查（提升编译速度）
    "skipLibCheck": true,

    /* Bundler 模式配置 */
    // 使用 bundler 模式解析模块（适配 Vite 等构建工具）
    "moduleResolution": "bundler",
    // 允许导入 .ts 文件时带扩展名
    "allowImportingTsExtensions": true,
    // 使用 verbatim 模块语法（需要显式 import/export）
    "verbatimModuleSyntax": true,
    // 强制检测模块
    "moduleDetection": "force",
    // 不生成输出文件（由 Vite 处理）
    "noEmit": true,

    /* 代码检查配置 */
    // 启用严格模式
    "strict": true,
    // 禁止未使用的局部变量
    "noUnusedLocals": true,
    // 禁止未使用的函数参数
    "noUnusedParameters": true,
    // 仅保留语法层面的类型擦除
    "erasableSyntaxOnly": true,
    // 禁止 switch fallthrough
    "noFallthroughCasesInSwitch": true,
    // 检查导入副作用
    "noUncheckedSideEffectImports": true
  },
  // 指定需要编译的文件（仅 Vite 配置文件）
  "include": ["vite.config.ts"]
}