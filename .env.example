# ============================================================
# 环境变量配置示例（复制为 .env 后修改）
# 注意：变量名必须以 VITE_ 开头才能被 Vite 识别并注入到前端
# ============================================================

# API 基础地址（不含 /api 路径，请求路径由 axios 拼接）
# - 本地开发：http://localhost:10000（直连 Gateway）或 http://localhost:80（走 Nginx）
# - 生产部署：http://your-domain.com 或 https://your-domain.com
VITE_API_BASE_URL=http://localhost:80