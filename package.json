    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "dompurify": "^3.4.11",
    "element-plus": "^2.14.1",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "^3.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^27.0.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.2.8"
  }
